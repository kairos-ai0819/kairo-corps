---
import { createTranslator, type Locale } from "~/i18n/utils";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = createTranslator(locale);
---

<footer class="border-t border-line/60 bg-paper">
  <div class="container-x py-10">
    <div class="flex flex-col items-start gap-6 md:flex-row md:items-center md:justify-between">
      <div>
        <div class="flex items-baseline gap-2">
          <span class="text-base font-semibold tracking-tight lowercase text-ink">kairos</span>
          <span class="text-xs text-muted">, Inc.</span>
        </div>
        <p class="mt-2 text-sm text-muted">{t("footer.tagline")}</p>
      </div>

      <div class="flex items-center gap-4">
        <a
          href="#"
          aria-label="X (Twitter)"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink/70 transition hover:border-ink hover:text-ink"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M18.244 2H21.5l-7.5 8.57L23 22h-6.844l-5.36-6.99L4.6 22H1.34l8.06-9.21L1 2h7.02l4.84 6.39L18.244 2Zm-2.4 18h1.86L7.24 4h-1.99l10.594 16Z"></path>
          </svg>
        </a>
        <a
          href="#"
          aria-label="GitHub"
          class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-line text-ink/70 transition hover:border-ink hover:text-ink"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path d="M12 .5C5.73.5.86 5.37.86 11.64c0 4.94 3.2 9.13 7.64 10.62.56.1.77-.25.77-.55v-1.94c-3.11.68-3.77-1.5-3.77-1.5-.51-1.3-1.25-1.65-1.25-1.65-1.02-.7.08-.69.08-.69 1.13.08 1.72 1.16 1.72 1.16 1 1.72 2.63 1.22 3.27.94.1-.73.39-1.22.71-1.5-2.48-.28-5.09-1.24-5.09-5.51 0-1.22.43-2.21 1.15-2.99-.12-.28-.5-1.42.11-2.96 0 0 .94-.3 3.07 1.14a10.6 10.6 0 0 1 5.6 0c2.13-1.44 3.07-1.14 3.07-1.14.61 1.54.23 2.68.11 2.96.72.78 1.15 1.77 1.15 2.99 0 4.28-2.62 5.22-5.11 5.5.4.35.76 1.03.76 2.07v3.07c0 .3.2.66.78.55 4.43-1.49 7.62-5.68 7.62-10.62C23.14 5.37 18.27.5 12 .5Z"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-8 border-t border-line pt-6 text-xs text-muted">
      {t("footer.copyright")}
    </div>
  </div>
</footer>
